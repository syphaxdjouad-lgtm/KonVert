# ─── SUPABASE ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── STRIPE ─────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Plans Stripe — créer dans Stripe Dashboard → Products
STRIPE_PRICE_STARTER=price_...   # Starter 39€/mois
STRIPE_PRICE_PRO=price_...       # Pro 79€/mois
STRIPE_PRICE_AGENCY=price_...    # Agency 199€/mois

# ─── GÉNÉRATION IA (DeepSeek — actif depuis mai 2026) ───
# OBLIGATOIRE en prod sinon 100% des générations échouent.
DEEPSEEK_API_KEY=sk-...

# ─── ANTHROPIC (legacy, garde la clé tant que dossier src/lib/anthropic existe) ─
ANTHROPIC_API_KEY=sk-ant-...

# ─── APP ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://konvertpilot.com

# ─── SHOPIFY ────────────────────────────────────────────
SHOPIFY_API_KEY=...
SHOPIFY_API_SECRET=...

# ─── EMAILS (Resend) ────────────────────────────────────
RESEND_API_KEY=re_...

# ─── CRON / INTERNAL ────────────────────────────────────
CRON_SECRET=...                # 32+ caractères, partagé Vercel cron + appels internes
ADMIN_SECRET=...               # 32+ caractères, auth de /admin/waitlist

# ─── CAPTCHA (Cloudflare Turnstile, gratuit) ────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# ─── RATE LIMIT (Upstash Redis, gratuit) ────────────────
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ─── MONITORING (Sentry, optionnel) ─────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...
SENTRY_DSN=https://...
SENTRY_ORG=...
SENTRY_PROJECT=konvert

# ─── SCRAPING (cascade routée par plateforme) ──────────
# AliExpress  → Bright Data direct (Firecrawl + ScrapingBee testés KO en stealth)
# Amazon/etc. → Firecrawl → ScrapingBee → Bright Data → fetch
#
# Tier 1 — Firecrawl stealth (Amazon, Shopify, etc.)
FIRECRAWL_API_KEY=fc-...
# Tier 2 — ScrapingBee premium_proxy (filet Amazon résistant, 25 credits/req)
SCRAPINGBEE_API_KEY=
# Tier 3 — Bright Data Web Unlocker (AliExpress + dernier filet)
#   - API token : dashboard Bright Data → Settings → API tokens
#   - Zone : créer une zone "Web Unlocker" dans Proxies & Scraping Infrastructure
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=
# Legacy (non utilisés)
SCRAPERAPI_KEY=...
APIFY_API_KEY=...

# ─── ANALYTICS (PostHog) ────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── CHAT SUPPORT (optionnel) ───────────────────────────
NEXT_PUBLIC_CRISP_WEBSITE_ID=...

# ─── SÉCURITÉ ───────────────────────────────────────────
ENCRYPTION_KEY=... # 32+ caractères aléatoires (chiffrement AES-256 des access tokens Shopify/Woo)

# ─── FEATURE FLAGS ──────────────────────────────────────
# Chantier A — sections riches DTC (spec 2026-05-23).
# 'false' = rollback rapide en prod sans rebuild (renderRichSections retourne '').
KONVERT_RICH_SECTIONS=true

# Chantier B — galerie multi-images (spec 2026-05-25).
# 'false' = rollback rapide en prod sans rebuild (renderHeroThumbs,
# renderGallery, et l'image dans renderUniqueMechanism retournent '').
KONVERT_GALLERY=true

# Chantier C1 — nouvel editor React custom (spec 2026-05-25).
# 'true' = utilise EditorRoot React. 'false' (ou absent) = legacy GrapesEditor.
# IMPORTANT : prefixe NEXT_PUBLIC_ car lu cote client (composant React).
NEXT_PUBLIC_KONVERT_NEW_EDITOR=true
