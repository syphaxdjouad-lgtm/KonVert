{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "Vibrant",
    "version": "1.0.0",
    "description": "Tokens du style Vibrant — Konvert V3. Vibe Tonies x Notion 2024 x Squarespace Creator. Joyeux, colore, propre.",
    "status": "ready",
    "createdAt": "2026-05-26",
    "author": "OBITO — NEXARA"
  },

  "color": {
    "$description": "Palette Vibrant — blanc + jaune creme + rose flash",

    "bg": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Fond principal — blanc pur. Sections alternees avec surface."
    },
    "surface": {
      "$value": "#FFF8E1",
      "$type": "color",
      "$description": "Fond secondaire — jaune creme. Alternance avec bg pour rythmer les sections sans border."
    },
    "accent": {
      "$value": "#FF4D88",
      "$type": "color",
      "$description": "Accent principal — rose flash. CTAs, pills, ombres colorees, badges, checkmarks, etoiles reviews."
    },
    "accentHover": {
      "$value": "#E03070",
      "$type": "color",
      "$description": "Accent hover — rose plus profond. Etat hover des boutons primaires."
    },
    "accentLight": {
      "$value": "rgba(255, 77, 136, 0.10)",
      "$type": "color",
      "$description": "Accent leger — fond des icones et des pills non-solid. 10% opacite."
    },
    "text": {
      "$value": "#1A1A1A",
      "$type": "color",
      "$description": "Texte principal. Quasi-noir, plus doux que #000. Contraste 18.1:1 sur blanc (AAA)."
    },
    "textMuted": {
      "$value": "#666666",
      "$type": "color",
      "$description": "Texte secondaire / descriptions. Contraste 5.74:1 sur blanc (AA)."
    },
    "border": {
      "$value": "#1A1A1A",
      "$type": "color",
      "$description": "Couleur des bordures — section-divider a 12% opacite, borders secondaires a 8-10%."
    },
    "white": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "Blanc pur — texte sur accent, footer fond noir, overlay nav."
    }
  },

  "typography": {
    "$description": "Typographie Vibrant — Clash Display pour les headings, Inter pour le body",

    "fontHeading": {
      "$value": "\"Clash Display\", \"Inter\", sans-serif",
      "$type": "fontFamily",
      "$description": "Police display — Clash Display (Fontshare). Geometric, friendly, personnalite forte. Fallback Inter."
    },
    "fontBody": {
      "$value": "\"Inter\", system-ui, sans-serif",
      "$type": "fontFamily",
      "$description": "Police corps — Inter. Neutre, lisible, universel."
    },
    "fontCdn": {
      "$value": "https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap",
      "$type": "string",
      "$description": "URL CDN Clash Display (Fontshare). Attention : heberger en production pour eviter la latence."
    },

    "scaleHero": {
      "$value": "clamp(52px, 7vw, 100px)",
      "$type": "dimension",
      "$description": "H1 hero desktop. Weight 700, tracking -0.025em, line-height 1.0."
    },
    "scaleH2": {
      "$value": "clamp(36px, 4.5vw, 64px)",
      "$type": "dimension",
      "$description": "H2 sections. Weight 700, tracking -0.02em, line-height 1.05."
    },
    "scaleH3": {
      "$value": "clamp(22px, 2.5vw, 32px)",
      "$type": "dimension",
      "$description": "H3 cards. Weight 600, tracking -0.015em, line-height 1.2."
    },
    "scaleBody": {
      "$value": "17px",
      "$type": "dimension",
      "$description": "Corps desktop. 16px sur mobile. Line-height 1.6."
    },
    "scaleSm": {
      "$value": "15px",
      "$type": "dimension",
      "$description": "Texte secondaire, descriptions de cards."
    },
    "scaleXs": {
      "$value": "13px",
      "$type": "dimension",
      "$description": "Labels, metadata, auteurs reviews, footers."
    },
    "scalePill": {
      "$value": "13px",
      "$type": "dimension",
      "$description": "Texte dans les pills. Weight 600, letter-spacing 0.01em."
    },
    "scaleManifestoPill": {
      "$value": "18px",
      "$type": "dimension",
      "$description": "Texte dans les pills de manifesto. Clash Display, weight 600, tracking -0.01em."
    }
  },

  "spacing": {
    "$description": "Espacement base 4px — section > card > gap",

    "section": {
      "$value": "120px",
      "$type": "dimension",
      "$description": "Padding vertical des sections desktop. 72px sur mobile."
    },
    "sectionMobile": {
      "$value": "72px",
      "$type": "dimension",
      "$description": "Padding vertical des sections mobile."
    },
    "card": {
      "$value": "32px",
      "$type": "dimension",
      "$description": "Padding interne des cards. 20px sur mobile."
    },
    "cardMobile": {
      "$value": "20px",
      "$type": "dimension",
      "$description": "Padding interne des cards mobile."
    },
    "gap": {
      "$value": "24px",
      "$type": "dimension",
      "$description": "Gap entre cards en grille. 12-16px sur mobile."
    },
    "gapMobile": {
      "$value": "12px",
      "$type": "dimension",
      "$description": "Gap entre cards mobile."
    },
    "container": {
      "$value": "1200px",
      "$type": "dimension",
      "$description": "Max-width du conteneur. Padding horizontal 48px desktop, 20px mobile."
    },
    "containerPaddingDesktop": {
      "$value": "48px",
      "$type": "dimension",
      "$description": "Padding horizontal conteneur desktop."
    },
    "containerPaddingMobile": {
      "$value": "20px",
      "$type": "dimension",
      "$description": "Padding horizontal conteneur mobile."
    },
    "navHeight": {
      "$value": "60px",
      "$type": "dimension",
      "$description": "Hauteur de la navbar desktop. 56px mobile."
    },
    "navHeightMobile": {
      "$value": "56px",
      "$type": "dimension",
      "$description": "Hauteur de la navbar mobile."
    }
  },

  "border": {
    "$description": "Rayons de bordure — genereux et friendly",

    "card": {
      "$value": "16px",
      "$type": "borderRadius",
      "$description": "Radius des cards. Genereux, friendly — signature du style Vibrant."
    },
    "button": {
      "$value": "999px",
      "$type": "borderRadius",
      "$description": "Radius des boutons — pill complet."
    },
    "image": {
      "$value": "16px",
      "$type": "borderRadius",
      "$description": "Radius des images et conteneurs image."
    },
    "pill": {
      "$value": "999px",
      "$type": "borderRadius",
      "$description": "Radius des pills / badges."
    },
    "icon": {
      "$value": "14px",
      "$type": "borderRadius",
      "$description": "Radius des conteneurs d'icones (why-icon, care-icon, best-for-icon)."
    },
    "badge": {
      "$value": "12px",
      "$type": "borderRadius",
      "$description": "Radius du badge flottant hero mobile / desktop."
    }
  },

  "shadow": {
    "$description": "Ombres colorees rose — signature du style Vibrant",

    "card": {
      "$value": "0 4px 16px rgba(255, 77, 136, 0.15)",
      "$type": "shadow",
      "$description": "Ombre repos des cards. Coloree accent rose a 15% opacite."
    },
    "hover": {
      "$value": "0 16px 40px rgba(255, 77, 136, 0.25)",
      "$type": "shadow",
      "$description": "Ombre hover des cards. Plus prononcee, 25% opacite."
    },
    "sm": {
      "$value": "0 2px 8px rgba(255, 77, 136, 0.08)",
      "$type": "shadow",
      "$description": "Ombre legere — elements secondaires."
    },
    "hero": {
      "$value": "0 24px 60px rgba(255, 77, 136, 0.30)",
      "$type": "shadow",
      "$description": "Ombre hero image au hover — maximum impact."
    },
    "floatBadge": {
      "$value": "0 8px 24px rgba(0, 0, 0, 0.12)",
      "$type": "shadow",
      "$description": "Ombre badge flottant — NON coloree. Effet realiste 'pose sur la photo'."
    }
  },

  "motion": {
    "$description": "Animations bouncey — signature du style Vibrant. Philosophie Jakub Krehel (production polish).",

    "easeBounce": {
      "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "$type": "cubicBezier",
      "$description": "Ease avec overshoot. Les elements 'pop'. Utilise sur fade-up, btn hover, variant selection."
    },
    "easeSmooth": {
      "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
      "$type": "cubicBezier",
      "$description": "Ease classique smooth. Utilise pour les transitions de couleur (border, background)."
    },
    "duration": {
      "$value": "400ms",
      "$type": "duration",
      "$description": "Duration standard des animations. Assez long pour percevoir le bounce, assez court pour ne pas irriter."
    },
    "durationFast": {
      "$value": "200ms",
      "$type": "duration",
      "$description": "Duration rapide — transitions de couleur, opacity."
    },
    "durationSlow": {
      "$value": "500ms",
      "$type": "duration",
      "$description": "Duration lente — image scale au hover."
    },

    "stagger1": {
      "$value": "80ms",
      "$type": "duration",
      "$description": "Delay du premier element en cascade (delay-1)."
    },
    "stagger2": {
      "$value": "160ms",
      "$type": "duration",
      "$description": "Delay du deuxieme element (delay-2)."
    },
    "stagger3": {
      "$value": "240ms",
      "$type": "duration",
      "$description": "Delay du troisieme element (delay-3)."
    },
    "stagger4": {
      "$value": "320ms",
      "$type": "duration",
      "$description": "Delay du quatrieme element (delay-4)."
    },

    "hoverTranslateY": {
      "$value": "-4px",
      "$type": "dimension",
      "$description": "TranslateY au hover des cards. -6px pour l'image hero."
    },
    "btnHoverScale": {
      "$value": "1.05",
      "$type": "number",
      "$description": "Scale au hover des boutons. Max 5% pour rester subtil."
    },
    "pillHoverScale": {
      "$value": "1.05",
      "$type": "number",
      "$description": "Scale au hover des pills manifesto."
    }
  },

  "components": {
    "$description": "Specifications des composants cles",

    "pill": {
      "paddingV": { "$value": "6px", "$type": "dimension" },
      "paddingH": { "$value": "16px", "$type": "dimension" },
      "fontSize": { "$value": "13px", "$type": "dimension" },
      "fontWeight": { "$value": "600", "$type": "number" },
      "borderRadius": { "$value": "999px", "$type": "borderRadius" },
      "bgLight": { "$value": "rgba(255, 77, 136, 0.10)", "$type": "color" },
      "bgSolid": { "$value": "#FF4D88", "$type": "color" },
      "colorLight": { "$value": "#FF4D88", "$type": "color" },
      "colorSolid": { "$value": "#FFFFFF", "$type": "color" }
    },

    "button": {
      "paddingV": { "$value": "16px", "$type": "dimension" },
      "paddingH": { "$value": "36px", "$type": "dimension" },
      "fontSize": { "$value": "16px", "$type": "dimension" },
      "fontWeight": { "$value": "600", "$type": "number" },
      "borderRadius": { "$value": "999px", "$type": "borderRadius" },
      "minHeightMobile": { "$value": "52px", "$type": "dimension", "$description": "Touch target WCAG AA" }
    },

    "card": {
      "borderRadius": { "$value": "16px", "$type": "borderRadius" },
      "padding": { "$value": "32px", "$type": "dimension" },
      "paddingMobile": { "$value": "20px", "$type": "dimension" },
      "bgOnWhite": { "$value": "#FFF8E1", "$type": "color", "$description": "Card sur section bg blanc" },
      "bgOnSurface": { "$value": "#FFFFFF", "$type": "color", "$description": "Card sur section surface creme" }
    },

    "icon": {
      "sizeDesktop": { "$value": "52px", "$type": "dimension" },
      "sizeMobile": { "$value": "44px", "$type": "dimension" },
      "borderRadius": { "$value": "14px", "$type": "borderRadius" },
      "bg": { "$value": "rgba(255, 77, 136, 0.10)", "$type": "color" },
      "iconSize": { "$value": "26px", "$type": "dimension" },
      "strokeColor": { "$value": "#FF4D88", "$type": "color" },
      "strokeWidth": { "$value": "1.8", "$type": "number" }
    },

    "accentUnderline": {
      "$description": "Soulignement decoratif sous le mot accent du hero",
      "height": { "$value": "4px", "$type": "dimension" },
      "borderRadius": { "$value": "2px", "$type": "borderRadius" },
      "color": { "$value": "#FF4D88", "$type": "color" },
      "opacity": { "$value": "0.35", "$type": "number" }
    },

    "sectionDivider": {
      "height": { "$value": "1px", "$type": "dimension" },
      "color": { "$value": "#1A1A1A", "$type": "color" },
      "opacity": { "$value": "0.12", "$type": "number" },
      "$description": "Separateur entre sections — 1px noir simple. Jamais decoratif."
    },

    "nav": {
      "height": { "$value": "60px", "$type": "dimension" },
      "bgOpacity": { "$value": "0.92", "$type": "number" },
      "blur": { "$value": "16px", "$type": "dimension" },
      "borderOpacity": { "$value": "0.08", "$type": "number" }
    },

    "manifesto": {
      "heroAspectRatio": {
        "$value": "21 / 8",
        "$type": "string",
        "$description": "Ratio de l'image panoramique en tete de manifesto"
      },
      "pillFontSize": { "$value": "18px", "$type": "dimension" },
      "pillPaddingV": { "$value": "14px", "$type": "dimension" },
      "pillPaddingH": { "$value": "24px", "$type": "dimension" }
    },

    "gallery": {
      "gridTemplateDesktop": {
        "$value": "2fr 1fr 1fr",
        "$type": "string",
        "$description": "Grille mosaic 3 colonnes desktop. Premiere colonne couvre 2 rangees."
      },
      "slideWidthMobile": { "$value": "260px", "$type": "dimension" },
      "slideWidthLargeMobile": { "$value": "300px", "$type": "dimension" }
    },

    "floatBadge": {
      "borderRadius": { "$value": "14px", "$type": "borderRadius" },
      "paddingV": { "$value": "14px", "$type": "dimension" },
      "paddingH": { "$value": "20px", "$type": "dimension" },
      "iconSize": { "$value": "36px", "$type": "dimension" },
      "iconBorderRadius": { "$value": "10px", "$type": "borderRadius" },
      "positionBottom": { "$value": "24px", "$type": "dimension" },
      "positionLeft": { "$value": "-24px", "$type": "dimension", "$description": "Sort du bord de l'image pour effet depth" }
    }
  },

  "a11y": {
    "$description": "Ratios de contraste verifies WCAG 2.1",

    "textOnBg": {
      "$value": "18.1:1",
      "$type": "string",
      "$description": "#1A1A1A sur #FFFFFF — AAA"
    },
    "textOnSurface": {
      "$value": "16.5:1",
      "$type": "string",
      "$description": "#1A1A1A sur #FFF8E1 — AAA"
    },
    "mutedOnBg": {
      "$value": "5.74:1",
      "$type": "string",
      "$description": "#666666 sur #FFFFFF — AA"
    },
    "whiteOnAccent": {
      "$value": "4.58:1",
      "$type": "string",
      "$description": "#FFFFFF sur #FF4D88 — AA (conforme, passe le minimum 4.5:1)"
    },
    "whiteOnDark": {
      "$value": "18.1:1",
      "$type": "string",
      "$description": "#FFFFFF sur #1A1A1A (footer) — AAA"
    },
    "touchTargetMin": {
      "$value": "44px",
      "$type": "dimension",
      "$description": "Taille minimum touch target mobile WCAG 2.1 Success Criterion 2.5.5"
    }
  }
}
