{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://konvert.app"
  },
  "crons": [
    {
      "path": "/api/cron/trial-emails",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/preview-emails",
      "schedule": "0 9 * * *"
    }
  ]
}
